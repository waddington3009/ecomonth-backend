# ===== SERVIDOR =====
PORT=3001
NODE_ENV=development

# ===== BANCO DE DADOS (MySQL na VPS EasyPanel) =====
# Projeto: memoria | Serviço MySQL: ecomonth
# Usuário: calel_eco | Banco: ecomonthdata | Host Interno: memoria_ecomonth
# Troque SUA_SENHA_AQUI pela senha do usuário calel_eco (veja em Credenciais no EasyPanel)
DATABASE_URL="mysql://calel_eco:SUA_SENHA_AQUI@memoria_ecomonth:3306/ecomonthdata"

# ===== JWT =====
# Gere chaves seguras com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-uma-chave-secreta-forte-de-pelo-menos-32-caracteres"
JWT_REFRESH_SECRET="troque-por-outra-chave-secreta-forte-diferente-da-anterior"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ===== CORS =====
# Pode ser múltiplas URLs separadas por vírgula
# Em produção, coloque a URL real do Netlify
FRONTEND_URL="http://localhost:3000,https://seu-app.netlify.app"
