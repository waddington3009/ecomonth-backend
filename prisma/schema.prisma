// =========================================
// ECO MONTH — PRISMA SCHEMA
// Banco de Dados Relacional Completo
// =========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================
// AUTH — Usuários e Sessões
// =============================================

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(150)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relações
  refreshTokens         RefreshToken[]
  accounts              Account[]
  categories            Category[]
  tags                  Tag[]
  transactions          Transaction[]
  transfers             Transfer[]
  creditCards           CreditCard[]
  creditCardPurchases   CreditCardPurchase[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  savingsGoals          SavingsGoal[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// =============================================
// MÓDULO 1: CORE — Contas, Categorias, Tags, Transações
// =============================================

model Account {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  name           String   @db.VarChar(100)
  type           AccountType
  initialBalance Decimal  @default(0.00) @map("initial_balance") @db.Decimal(12, 2)
  color          String   @default("#3b82f6") @db.VarChar(7)
  icon           String   @default("wallet") @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  creditCards  CreditCard[]
  recurring    RecurringTransaction[]

  @@map("accounts")
}

enum AccountType {
  carteira
  conta_corrente
  poupanca
  investimento
  outro
}

model Category {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  parentId  Int?      @map("parent_id")
  name      String    @db.VarChar(100)
  type      CategoryType
  icon      String    @default("tag") @db.VarChar(50)
  color     String    @default("#64748b") @db.VarChar(7)
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")

  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("SubCategories", fields: [parentId], references: [id], onDelete: Cascade)
  children     Category[]   @relation("SubCategories")
  transactions Transaction[]
  budgets      Budget[]
  recurring    RecurringTransaction[]
  purchases    CreditCardPurchase[]

  @@map("categories")
}

enum CategoryType {
  receita
  despesa
}

model Tag {
  id     Int    @id @default(autoincrement())
  userId Int    @map("user_id")
  name   String @db.VarChar(50)
  color  String @default("#8b5cf6") @db.VarChar(7)

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionTags  TransactionTag[]

  @@unique([userId, name])
  @@map("tags")
}

model Transaction {
  id            Int               @id @default(autoincrement())
  userId        Int               @map("user_id")
  accountId     Int?              @map("account_id")
  categoryId    Int?              @map("category_id")
  creditCardId  Int?              @map("credit_card_id")
  invoiceId     Int?              @map("invoice_id")
  recurringId   Int?              @map("recurring_id")
  purchaseId    Int?              @map("purchase_id")
  type          TransactionType
  description   String            @db.VarChar(255)
  amount        Decimal           @db.Decimal(12, 2)
  date          DateTime          @db.Date
  dueDate       DateTime?         @map("due_date") @db.Date
  paidDate      DateTime?         @map("paid_date") @db.Date
  status        TransactionStatus @default(pendente)
  notes         String?           @db.Text
  installmentInfo String?         @map("installment_info") @db.VarChar(20)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  account           Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category          Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creditCard        CreditCard?           @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  invoice           CreditCardInvoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  recurring         RecurringTransaction? @relation(fields: [recurringId], references: [id], onDelete: SetNull)
  purchase          CreditCardPurchase?   @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  transactionTags   TransactionTag[]
  transfersFrom     Transfer[]            @relation("TransferFrom")
  transfersTo       Transfer[]            @relation("TransferTo")

  @@index([userId, date])
  @@index([userId, status])
  @@index([userId, type, date])
  @@map("transactions")
}

enum TransactionType {
  receita
  despesa
  transferencia
}

enum TransactionStatus {
  pendente
  pago
  cancelado
}

model TransactionTag {
  transactionId Int @map("transaction_id")
  tagId         Int @map("tag_id")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}

model Transfer {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  fromTransactionId Int      @map("from_transaction_id")
  toTransactionId   Int      @map("to_transaction_id")
  amount            Decimal  @db.Decimal(12, 2)
  date              DateTime @db.Date
  description       String?  @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at")

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromTransaction Transaction @relation("TransferFrom", fields: [fromTransactionId], references: [id], onDelete: Cascade)
  toTransaction   Transaction @relation("TransferTo", fields: [toTransactionId], references: [id], onDelete: Cascade)

  @@map("transfers")
}

// =============================================
// MÓDULO 2: CARTÕES DE CRÉDITO
// =============================================

model CreditCard {
  id               Int            @id @default(autoincrement())
  userId           Int            @map("user_id")
  paymentAccountId Int?           @map("payment_account_id")
  name             String         @db.VarChar(100)
  brand            CardBrand      @default(outro)
  lastFourDigits   String?        @map("last_four_digits") @db.Char(4)
  creditLimit      Decimal        @map("credit_limit") @db.Decimal(12, 2)
  closingDay       Int            @map("closing_day") @db.TinyInt
  dueDay           Int            @map("due_day") @db.TinyInt
  color            String         @default("#6366f1") @db.VarChar(7)
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentAccount Account?              @relation(fields: [paymentAccountId], references: [id], onDelete: SetNull)
  invoices       CreditCardInvoice[]
  purchases      CreditCardPurchase[]
  transactions   Transaction[]

  @@map("credit_cards")
}

enum CardBrand {
  visa
  mastercard
  elo
  amex
  hipercard
  outro
}

model CreditCardInvoice {
  id             Int           @id @default(autoincrement())
  creditCardId   Int           @map("credit_card_id")
  referenceMonth Int           @map("reference_month") @db.TinyInt
  referenceYear  Int           @map("reference_year") @db.SmallInt
  closingDate    DateTime      @map("closing_date") @db.Date
  dueDate        DateTime      @map("due_date") @db.Date
  totalAmount    Decimal       @default(0.00) @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0.00) @map("paid_amount") @db.Decimal(12, 2)
  status         InvoiceStatus @default(aberta)
  paymentDate    DateTime?     @map("payment_date") @db.Date
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  creditCard   CreditCard    @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([creditCardId, referenceMonth, referenceYear])
  @@map("credit_card_invoices")
}

enum InvoiceStatus {
  aberta
  fechada
  paga
  parcial
}

model CreditCardPurchase {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  creditCardId       Int      @map("credit_card_id")
  categoryId         Int?     @map("category_id")
  description        String   @db.VarChar(255)
  totalAmount        Decimal  @map("total_amount") @db.Decimal(12, 2)
  installmentAmount  Decimal  @map("installment_amount") @db.Decimal(12, 2)
  totalInstallments  Int      @default(1) @map("total_installments") @db.TinyInt
  purchaseDate       DateTime @map("purchase_date") @db.Date
  createdAt          DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard   CreditCard    @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@map("credit_card_purchases")
}

// =============================================
// MÓDULO 3: AUTOMAÇÃO — Recorrência
// =============================================

model RecurringTransaction {
  id           Int               @id @default(autoincrement())
  userId       Int               @map("user_id")
  accountId    Int?              @map("account_id")
  categoryId   Int?              @map("category_id")
  type         CategoryType
  description  String            @db.VarChar(255)
  amount       Decimal           @db.Decimal(12, 2)
  frequency    Frequency         @default(mensal)
  dayOfMonth   Int?              @map("day_of_month") @db.TinyInt
  startDate    DateTime          @map("start_date") @db.Date
  endDate      DateTime?         @map("end_date") @db.Date
  isActive     Boolean           @default(true) @map("is_active")
  autoMarkPaid Boolean           @default(false) @map("auto_mark_paid")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category     Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@map("recurring_transactions")
}

enum Frequency {
  semanal
  quinzenal
  mensal
  anual
}

// =============================================
// MÓDULO 4: ORÇAMENTO E METAS
// =============================================

model Budget {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  categoryId      Int      @map("category_id")
  month           Int      @db.TinyInt
  year            Int      @db.SmallInt
  limitAmount     Decimal  @map("limit_amount") @db.Decimal(12, 2)
  alertPercentage Int      @default(80) @map("alert_percentage") @db.TinyInt
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@map("budgets")
}

model SavingsGoal {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  name          String   @db.VarChar(100)
  targetAmount  Decimal  @map("target_amount") @db.Decimal(12, 2)
  currentAmount Decimal  @default(0.00) @map("current_amount") @db.Decimal(12, 2)
  deadline      DateTime? @db.Date
  icon          String   @default("piggy-bank") @db.VarChar(50)
  color         String   @default("#22c55e") @db.VarChar(7)
  isCompleted   Boolean  @default(false) @map("is_completed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions SavingsGoalContribution[]

  @@map("savings_goals")
}

model SavingsGoalContribution {
  id        Int              @id @default(autoincrement())
  goalId    Int              @map("goal_id")
  amount    Decimal          @db.Decimal(12, 2)
  type      ContributionType
  date      DateTime         @db.Date
  note      String?          @db.VarChar(255)
  createdAt DateTime         @default(now()) @map("created_at")

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("savings_goal_contributions")
}

enum ContributionType {
  deposito
  retirada
}
